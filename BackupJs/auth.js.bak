    function doLogin() {
        // In a real app, you would validate credentials via AJAX/POST
        // For this refactoring, we'll redirect to the router with a login action
        window.location.href = 'index.php?action=login';
    }

    function doLogout() {
        // Redirect to the router with a logout action
        window.location.href = 'index.php?action=logout';
    }
